generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  ZOMATO
  SWIGGY
}

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
}

enum PolicyStatus {
  ACTIVE
  INACTIVE
}

enum TriggerType {
  RAIN
  AQI
  OUTAGE
}

enum ClaimStatus {
  INITIATED
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PROCESSED
  PENDING
}

model User {
  id               Int       @id @default(autoincrement())
  fullName         String
  phone            String    @unique
  platform         Platform?
  city             String?
  zone             String?
  avgDailyEarnings Float?
  upiId            String?
  createdAt        DateTime  @default(now())
  policies         Policy[]
  claims           Claim[]
  password         String
  role             String    @default("WORKER")
}

model Policy {
  id              Int          @id @default(autoincrement())
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  planType        PlanType
  weeklyPremium   Float
  maxWeeklyPayout Float
  status          PolicyStatus @default(INACTIVE)
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime     @default(now())
  claims          Claim[]

  @@index([userId, status])
}

model TriggerEvent {
  id          Int         @id @default(autoincrement())
  triggerType TriggerType
  zone        String
  severity    String
  source      String
  detectedAt  DateTime    @default(now())
  claims      Claim[]

  @@index([zone, triggerType])
}

model Claim {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  policyId       Int
  policy         Policy       @relation(fields: [policyId], references: [id])
  triggerEventId Int
  triggerEvent   TriggerEvent @relation(fields: [triggerEventId], references: [id])
  payoutAmount   Float
  status         ClaimStatus  @default(INITIATED)
  createdAt      DateTime     @default(now())
  payout         Payout?

  @@unique([policyId, triggerEventId])
  @@index([userId, createdAt])
}

model Payout {
  id           Int          @id @default(autoincrement())
  claimId      Int          @unique
  claim        Claim        @relation(fields: [claimId], references: [id])
  payoutStatus PayoutStatus @default(PROCESSED)
  payoutMethod String
  processedAt  DateTime     @default(now())
}
